10)https://www.hackerrank.com/challenges/nested-list/problem?isFullScreen=true
----
# Read number of students
n = int(input())

# Read students' data into a list of [name, grade]
students = []
for _ in range(n):
    name = input()
    grade = float(input())
    students.append([name, grade])

# Extract all unique grades and sort them
grades = sorted({grade for name, grade in students})

# Find the second lowest grade
second_lowest = grades[1]

# Get names of students who have the second lowest grade
second_lowest_students = [name for name, grade in students if grade == second_lowest]

# Sort names alphabetically
second_lowest_students.sort()

# Print names
for name in second_lowest_students:
    print(name)

