from itertools import combinations

n = int(input())
letters = input().split()
k = int(input())

indices = list(range(n))
total = 0
favorable = 0

for comb in combinations(indices, k):
    total += 1
    if any(letters[i] == 'a' for i in comb):
        favorable += 1

print(f"{favorable / total:.4f}")
